    {
      "name": "Payments",
      "description": "M-Pesa STK Push, polling, IPN callback, history",
      "item": [
        {
          "name": "Initiate Unlock Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/initiate",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{TEST_LISTING_ID}}\",\n  \"paymentType\": \"unlock\",\n  \"phone\": \"{{MPESA_TEST_PHONE}}\",\n  \"idempotencyKey\": \"{{$guid}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 202', () => pm.response.to.have.status(202));",
                  "const res = pm.response.json();",
                  "pm.test('Has checkoutRequestId', () => pm.expect(res.data.checkoutRequestId).to.be.a('string'));",
                  "pm.test('Status is pending', () => pm.expect(res.data.status).to.equal('pending'));",
                  "pm.environment.set('TEST_CHECKOUT_ID', res.data.checkoutRequestId);",
                  "pm.environment.set('TEST_PAYMENT_ID', res.data.paymentId);",
                  "console.log('Checkout ID saved:', res.data.checkoutRequestId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Poll Payment Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/{{TEST_CHECKOUT_ID}}/status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Has status field', () => pm.expect(res.data.status).to.be.oneOf(['pending','processing','completed','failed','cancelled','timeout']));",
                  "console.log('Payment status:', res.data.status);"
                ]
              }
            }
          ]
        },
        {
          "name": "Simulate IPN Callback (SUCCESS)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/callback",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Body\": {\n    \"stkCallback\": {\n      \"MerchantRequestID\": \"test-merchant-req-001\",\n      \"CheckoutRequestID\": \"{{TEST_CHECKOUT_ID}}\",\n      \"ResultCode\": 0,\n      \"ResultDesc\": \"The service request is processed successfully.\",\n      \"CallbackMetadata\": {\n        \"Item\": [\n          { \"Name\": \"Amount\", \"Value\": 499 },\n          { \"Name\": \"MpesaReceiptNumber\", \"Value\": \"QKA1B2C3D4\" },\n          { \"Name\": \"TransactionDate\", \"Value\": 20260508103015 },\n          { \"Name\": \"PhoneNumber\", \"Value\": 254712345678 }\n        ]\n      }\n    }\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Always 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('ResultCode 0', () => pm.expect(res.ResultCode).to.equal(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "Simulate IPN Callback (CANCELLED)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/callback",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
