# Database — local dev: postgres://postgres:password@localhost:5432/kejafinder_dev
# Staging: use Cloud SQL Auth Proxy on port 5433
DATABASE_URL=postgres://postgres:password@localhost:5432/kejafinder_dev

# Redis — local dev
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK service account key path
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=kejafinder-dev
# Firebase Storage bucket — found in Firebase console > Storage > bucket name
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# M-Pesa Daraja API (Safaricom Sandbox)
MPESA_CONSUMER_KEY=your_sandbox_consumer_key
MPESA_CONSUMER_SECRET=your_sandbox_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_sandbox_passkey
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/v1/payments/callback
MPESA_ENV=sandbox

# Cloudinary
CLOUDINARY_CLOUD_NAME=kejafinder
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# API
PORT=3001
API_BASE_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=info

# Docs (set to true in dev/staging, false in production)
DOCS_ENABLED=true
